<Window x:Class="RevitGpt.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revit Assistant" Height="600" Width="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <RichTextBox x:Name="ChatHistory" Grid.Row="0" Margin="10" 
                     VerticalScrollBarVisibility="Auto" 
                     IsReadOnly="True"/>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UserInput" Grid.Column="0" 
                     Height="40" VerticalAlignment="Center"
                     AcceptsReturn="True" TextWrapping="Wrap" 
                     KeyDown="UserInput_KeyDown"/>

            <Button x:Name="SendButton" Grid.Column="1" Content="Send" 
                    Width="60" Height="30" Margin="5,0,0,0"
                    Click="SendButton_Click"/>

            <Button x:Name="TestButton" Grid.Column="2" Content="Test" 
                    Width="60" Height="30" Margin="5,0,0,0"
                    Background="#FFADD8E6" 
                    Click="TestButton_Click"/>
        </Grid>
    </Grid>
</Window>